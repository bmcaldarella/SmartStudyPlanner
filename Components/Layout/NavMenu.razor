﻿﻿﻿@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">

    <!-- Application title / branding -->
    <div class="container-fluid">
        <a class="navbar-brand" href="">📚 Study Planner</a>
    </div>
</div>


<!-- Sidebar navigation menu -->
<div class="nav-scrollable"
     onclick="document.querySelector('.navbar-toggler').checked = false">
    <nav class="flex-column">

        <!-- Public navigation links -->
        <div class="nav-item px-3">
            <NavLink href="" class="nav-link" Match="NavLinkMatch.All">
                <span class="bi bi-house-door" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink href="/about" class="nav-link">
                <span class="bi bi-info-circle" aria-hidden="true"></span> About
            </NavLink>
        </div>

        <!-- Links only visible to authenticated users -->
        <AuthorizeView>
            <Authorized>
                <hr class="nav-divider" />

                <div class="nav-item px-3">
                    <NavLink href="/planner" class="nav-link">
                        <span class="bi bi-grid-3x3-gap" aria-hidden="true"></span> Dashboard
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink href="/planner/add" class="nav-link">
                        <span class="bi bi-plus-circle" aria-hidden="true"></span> Add New Task
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink href="/planner/subjects" class="nav-link">
                        <span class="bi bi-book" aria-hidden="true"></span> My Subjects
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>