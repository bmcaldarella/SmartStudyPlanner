﻿@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<div class="nav-wrapper">
    <div class="nav-inner">
        <a class="navbar-brand" href="">Smart Study</a>

        <input type="checkbox" id="nav-toggle" class="nav-toggle" />
        <label for="nav-toggle" class="nav-toggle-button" aria-label="Toggle navigation">
            <span></span>
            <span></span>
            <span></span>
        </label>

        <div class="nav-menu-area">
            <nav class="nav-links">
                <NavLink href="" class="nav-link" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door nav-icon" aria-hidden="true"></span>
                    <span>Home</span>
                </NavLink>

                <NavLink href="/about" class="nav-link">
                    <span class="bi bi-info-circle nav-icon" aria-hidden="true"></span>
                    <span>About</span>
                </NavLink>

                <AuthorizeView>
                    <Authorized>
                        <NavLink href="/planner" class="nav-link">
                            <span class="bi bi-grid-3x3-gap nav-icon" aria-hidden="true"></span>
                            <span>Dashboard</span>
                        </NavLink>

                        <NavLink href="/planner/add" class="nav-link">
                            <span class="bi bi-plus-circle nav-icon" aria-hidden="true"></span>
                            <span>New Task</span>
                        </NavLink>

                        <NavLink href="/planner/subjects" class="nav-link">
                            <span class="bi bi-book nav-icon" aria-hidden="true"></span>
                            <span>Subjects</span>
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
            </nav>

            <div class="nav-auth">
                <AuthorizeView>
                    <Authorized>
                        <span class="welcome-text">
                            @context.User.Identity?.Name?.Split('@')[0]
                        </span>
                        <form method="post" action="/Account/Logout" class="logout-form">
                            <button type="submit" class="logout-button">Log out</button>
                        </form>
                    </Authorized>

                    <NotAuthorized>
                        <a href="/Account/Login" class="top-link">Log in</a>
                        <a href="/Account/Register" class="top-link top-link-primary">Register</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</div>