@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">

            <!-- Shows different UI depending on authentication state -->
            <AuthorizeView>

                <!-- Displayed when the user is logged in -->
                <Authorized>
                    <span>Hello, @context.User.Identity?.Name!</span>

                    <!-- Sends POST request to log the user out -->
                    <form method="post" action="/Account/Logout" style="display: inline;">
                        <button type="submit" class="btn btn-link nav-link ms-3"
                                style="padding: 0; border: 0; background: none;">Log out</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/Account/Login">Log in</a>
                    <a href="/Account/Register" class="ms-3">Register</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <!-- Where routed page content is rendered -->
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>