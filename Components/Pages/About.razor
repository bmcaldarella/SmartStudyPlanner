@page "/about"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>About - Study Planner</PageTitle>

<div class="container py-5">

    <!-- HEADER -->
    <div class="text-center mb-5">
        <h1 class="fw-bold">About Study Planner</h1>
        <p class="lead text-muted mx-auto" style="max-width: 700px;">
            Study Planner is a simple and focused web application designed to help students,
            especially online learners, manage their academic responsibilities more effectively.
        </p>
    </div>

    <!-- CONTENT -->
    <div class="row g-4 justify-content-center">

        <!-- OUR GOAL -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h4 class="fw-semibold mb-3">Our Goal</h4>
                    <p class="text-muted">
                        Many students struggle with balancing coursework, assignments, and personal life.
                        Traditional tools like notebooks or generic to-do applications often fall short.
                    </p>
                    <p class="text-muted">
                        Study Planner provides a clean, student-centered platform to organize tasks by subject,
                        track deadlines, and monitor progress.
                    </p>
                </div>
            </div>
        </div>

        <!-- KEY FEATURES -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h4 class="fw-semibold mb-3">Key Features</h4>
                    <ul class="ps-3 text-muted">
                        <li class="mb-2">Create, edit, and delete study tasks</li>
                        <li class="mb-2">Set deadlines for assignments</li>
                        <li class="mb-2">Organize tasks by subject or course</li>
                        <li class="mb-2">Mark tasks as completed</li>
                        <li class="mb-2">Secure user accounts</li>
                    </ul>
                </div>
            </div>
        </div>

    </div>

    <!-- FOOTER -->
    <div class="text-center mt-5">
        <p class="text-muted small">
            Developed as part of Team 14's academic project.
        </p>
    </div>

</div>