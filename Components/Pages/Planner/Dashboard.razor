@page "/planner"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject TaskService TaskService
@inject SubjectService SubjectService

<PageTitle>Dashboard - Study Planner</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="mb-1">Dashboard</h1>
            <p class="text-muted mb-0">A quick overview of your study progress.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/planner/add" class="btn btn-primary">Add New Task</a>
            <a href="/planner/subjects" class="btn btn-outline-secondary">Manage Subjects</a>
        </div>
    </div>

    @if (isLoading)
    {
        <!-- Loading state while fetching dashboard data -->
        <div class="text-center py-5">
            <div class="spinner-border" role="status"></div>
            <p class="mt-3 text-muted">Loading your dashboard...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <!-- Displays error if data fails to load -->
        <div class="alert alert-danger">@errorMessage</div>
    }
    else
    {
        <!-- Summary statistics cards -->
        <div class="row g-4 mb-4">
            <!-- Total tasks -->
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <p class="text-muted mb-2">Total Tasks</p>
                        <h2 class="mb-0">@allTasks.Count</h2>
                    </div>
                </div>
            </div>

            <!-- Pending tasks -->
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <p class="text-muted mb-2">Pending</p>
                        <h2 class="mb-0">@pendingTasks.Count</h2>
                    </div>
                </div>
            </div>

            <!-- Completed tasks -->
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <p class="text-muted mb-2">Completed</p>
                        <h2 class="mb-0">@completedTasks.Count</h2>
                    </div>
                </div>
            </div>

            <!-- Subjects count -->
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <p class="text-muted mb-2">Subjects</p>
                        <h2 class="mb-0">@subjects.Count</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main dashboard content -->
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card shadow-sm border-0">
                    <div class="card-body">

                        <!-- Section header with pending count -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="mb-0">Upcoming Tasks</h4>
                            <span class="badge text-bg-light">@pendingTasks.Count pending</span>
                        </div>

                        <!-- Filtering and sorting controls -->
                        <div class="d-flex gap-2 mb-3 flex-wrap">

                            <!-- Filter by priority -->
                            <select class="form-select w-auto" @bind="filterStatus">
                                <option value="all">All Priorities</option>
                                <option value="high">High</option>
                                <option value="medium">Medium</option>
                                <option value="low">Low</option>
                            </select>

                            <!-- Filter by subject -->
                            <select class="form-select w-auto" @bind="selectedSubjectId">
                                <option value="0">All Subjects</option>

                                @foreach (var subject in subjects)
                                {
                                    <option value="@subject.Id">@subject.Name</option>
                                }
                            </select>

                            <!-- Sorting options -->
                            <select class="form-select w-auto" @bind="sortOption">
                                <option value="deadline">Sort by Deadline</option>
                                <option value="priority">Sort by Priority</option>
                            </select>

                        </div>

                        @if (!pendingTasks.Any())
                        {
                            <!-- Empty state when no pending tasks -->
                            <div class="text-center py-4">
                                <p class="text-muted mb-3">You're caught up! No pending tasks yet.</p>
                                <a href="/planner/add" class="btn btn-primary">Create your first task</a>
                            </div>
                        }
                        else
                        {
                            <!-- Task list -->
                            <div class="list-group list-group-flush">
                                @foreach (var task in GetFilteredTasks())
                                {
                                    <div class="list-group-item px-0 mb-2" style="
                                        border-left: 7px solid @(task.Subject?.Color ?? "#0d6efd");
                                        padding-left: 12px;
                                        border-radius: 8px;
                                        ">
                                        <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap" style="margin-left: 8px;">
                                            <div>
                                                <h6 class="mb-1">@task.Title</h6>

                                                <!-- Task metadata -->
                                                <div class="small text-muted d-flex gap-3 flex-wrap">
                                                    <span>@(task.Subject?.Name ?? "No subject")</span>
                                                    <span>@GetPriorityLabel(task.Priority)</span>
                                                    <span>@FormatDeadline(task.Deadline)</span>

                                                    <!-- Status badge based on deadline and completion -->
                                                    <span class="badge @GetStatusBadgeClass(task)">
                                                        @GetStatusLabel(task)
                                                    </span>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(task.Description))
                                                {
                                                    <p class="mb-0 mt-2 text-muted small">@task.Description</p>
                                                }
                                            </div>

                                            <!-- Task actions -->
                                            <div class="d-flex gap-2">
                                                <a href="/planner/edit/@task.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                                <button class="btn btn-sm btn-success" @onclick="() => MarkCompleted(task.Id)">
                                                    Mark Complete
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar: subjects + completed tasks -->
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <h4 class="mb-3">Subjects</h4>

                        @if (!subjects.Any())
                        {
                            <p class="text-muted mb-3">No subjects yet.</p>
                            <a href="/planner/subjects" class="btn btn-outline-primary btn-sm">Create Subject</a>
                        }
                        else
                        {
                            <!-- List of subjects with task counts -->
                            <div class="list-group list-group-flush">
                                @foreach (var subject in subjects)
                                {
                                    <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="rounded-circle d-inline-block"
                                                  style="width:12px;height:12px;background:@(subject.Color ?? "#0d6efd");"></span>
                                            <span>@subject.Name</span>
                                        </div>
                                        <span class="badge text-bg-light">@GetTaskCountForSubject(subject.Id)</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h4 class="mb-3">Recently Completed</h4>

                        @if (!completedTasks.Any())
                        {
                            <p class="text-muted mb-0">No completed tasks yet.</p>
                        }
                        else
                        {
                            <!-- Recently completed tasks -->
                            <div class="list-group list-group-flush">
                                @foreach (var task in completedTasks.Take(5))
                                {
                                    <div class="list-group-item px-0 mb-2" style="
                                        border-left: 7px solid @(task.Subject?.Color ?? "#0d6efd");
                                        padding-left: 12px;
                                        border-radius: 8px;
                                        ">
                                        <div class="d-flex justify-content-between align-items-center gap-3" style="margin-left: 8px;">
                                            <div>
                                                <div class="fw-semibold">@task.Title</div>
                                                <div class="small text-muted d-flex gap-2 flex-wrap">
                                                    <span>@(task.Subject?.Name ?? "No subject")</span>
                                                    <span>@FormatDeadline(task.Deadline)</span>
                                                    <span class="badge text-bg-success">Completed</span>
                                                </div>
                                            </div>

                                            <!-- Undo completion -->
                                            <div class="d-flex gap-2">
                                                <a href="/planner/edit/@task.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => MarkPending(task.Id)">
                                                    Undo
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // Data collections used in the dashboard
    private List<StudyTask> allTasks = new();
    private List<StudyTask> pendingTasks = new();
    private List<StudyTask> completedTasks = new();
    private List<Subject> subjects = new();

    // UI state
    private bool isLoading = true;
    private string? errorMessage;

    /// <summary>
    /// Loads all dashboard data when the page initializes
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    /// <summary>
    /// Retrieves tasks and subjects from services
    /// </summary>
    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            allTasks = await TaskService.GetTasksByUserAsync();
            pendingTasks = await TaskService.GetPendingTasksAsync();
            completedTasks = await TaskService.GetCompletedTasksAsync();
            subjects = await SubjectService.GetSubjectsByUserAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load dashboard data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Marks a task as completed and refreshes the dashboard
    /// </summary>
    private async Task MarkCompleted(int taskId)
    {
        await TaskService.MarkTaskAsCompletedAsync(taskId);
        await LoadData();
    }

    /// <summary>
    /// Marks a task as pending (undo completion)
    /// </summary>
    private async Task MarkPending(int taskId)
    {
        await TaskService.MarkTaskAsPendingAsync(taskId);
        await LoadData();
    }

    /// <summary>
    /// Formats deadline for display
    /// </summary>
    private string FormatDeadline(DateTime? deadline)
    {
        return deadline.HasValue ? deadline.Value.ToString("dd MMM yyyy, HH:mm") : "No deadline";
    }

    /// <summary>
    /// Converts numeric priority into readable label
    /// </summary>
    private string GetPriorityLabel(int priority)
    {
        return priority switch
        {
            3 => "High",
            2 => "Medium",
            _ => "Low"
        };
    }

    /// <summary>
    /// Returns number of tasks for a given subject
    /// </summary>
    private int GetTaskCountForSubject(int subjectId)
    {
        return allTasks.Count(t => t.SubjectId == subjectId);
    }

    // Filtering and sorting options
    private string filterStatus = "all"; // all, high, medium, low
    private string sortOption = "deadline"; // deadline or priority
    private int selectedSubjectId = 0; // 0 = all

    /// <summary>
    /// Applies filtering and sorting to pending tasks
    /// </summary>
    private IEnumerable<StudyTask> GetFilteredTasks()
    {
        var tasks = pendingTasks.AsEnumerable();

        // Filter by priority
        if (filterStatus == "high")
            tasks = tasks.Where(t => t.Priority == 3);
        else if (filterStatus == "medium")
            tasks = tasks.Where(t => t.Priority == 2);
        else if (filterStatus == "low")
            tasks = tasks.Where(t => t.Priority == 1);

        // Filter by subject
        if (selectedSubjectId != 0)
        {
            tasks = tasks.Where(t => t.SubjectId == selectedSubjectId);
        }

        // Apply sorting
        tasks = sortOption switch
        {
            "priority" => tasks.OrderByDescending(t => t.Priority),
            _ => tasks.OrderBy(t => t.Deadline ?? DateTime.MaxValue)
        };

        return tasks.Take(8);
    }

    /// <summary>
    /// Returns CSS class for task status badge
    /// </summary>
    private string GetStatusBadgeClass(StudyTask task)
    {
        if (task.IsCompleted)
            return "text-bg-success";

        if (task.Deadline.HasValue)
        {
            var now = DateTime.Now;

            if (task.Deadline.Value < now)
                return "text-bg-danger"; // overdue

            if (task.Deadline.Value < now.AddDays(2))
                return "text-bg-warning"; // due soon
        }

        return "text-bg-secondary";
    }

    /// <summary>
    /// Returns readable status label for a task
    /// </summary>
    private string GetStatusLabel(StudyTask task)
    {
        if (task.IsCompleted)
            return "Completed";

        if (task.Deadline.HasValue)
        {
            var now = DateTime.Now;

            if (task.Deadline.Value < now)
                return "Overdue";

            if (task.Deadline.Value < now.AddDays(2))
                return "Due Soon";
        }

        return "Pending";
    }
}