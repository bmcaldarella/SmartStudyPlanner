@page "/planner/add"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@inject TaskService TaskService
@inject SubjectService SubjectService
@inject NavigationManager NavigationManager

<PageTitle>Add Task - Study Planner</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="mb-4">
                <h1 class="mb-1">Add New Task</h1>
                <p class="text-muted mb-0">Create a study task and assign it to one of your subjects.</p>
            </div>

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success">@successMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border" role="status"></div>
                    <p class="mt-3 text-muted">Loading subjects...</p>
                </div>
            }
            else if (!subjects.Any())
            {
                <div class="card shadow-sm border-0">
                    <div class="card-body text-center py-5">
                        <h4 class="mb-3">You need a subject first</h4>
                        <p class="text-muted mb-4">
                            Before creating a task, create at least one subject so the task has somewhere to belong.
                        </p>
                        <a href="/planner/subjects" class="btn btn-primary">Go to My Subjects</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <EditForm Model="taskModel" OnValidSubmit="HandleSubmit" FormName="taskForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="alert alert-danger" />

                            <div class="mb-3">
                                <label class="form-label">Task Title</label>
                                <InputText class="form-control" @bind-Value="taskModel.Title" />
                                <ValidationMessage For="() => taskModel.Title" class="text-danger" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <InputTextArea class="form-control" rows="4" @bind-Value="taskModel.Description" />
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Subject</label>
                                    <InputSelect class="form-select" @bind-Value="taskModel.SubjectId">
                                        <option value="0">Select a subject</option>
                                        @foreach (var subject in subjects)
                                        {
                                            <option value="@subject.Id">@subject.Name</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => taskModel.SubjectId" class="text-danger" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Priority</label>
                                    <InputSelect class="form-select" @bind-Value="taskModel.Priority">
                                        <option value="1">Low</option>
                                        <option value="2">Medium</option>
                                        <option value="3">High</option>
                                    </InputSelect>
                                </div>
                            </div>

                            <div class="mt-3 mb-4">
                                <label class="form-label">Deadline</label>
                                <input type="datetime-local" class="form-control" value="@deadlineInput" @onchange="OnDeadlineChanged" />
                            </div>

                            <div class="d-flex gap-2 flex-wrap">
                                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <span>Create Task</span>
                                    }
                                </button>

                                <a href="/planner" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Subject> subjects = new();
    private CreateTaskModel taskModel = new();
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;
    private string? successMessage;
    private string? deadlineInput;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubjects();
    }

    private async Task LoadSubjects()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            subjects = await SubjectService.GetSubjectsByUserAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load subjects: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnDeadlineChanged(ChangeEventArgs e)
    {
        deadlineInput = e.Value?.ToString();
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        successMessage = null;

        if (taskModel.SubjectId <= 0)
        {
            errorMessage = "Please select a subject.";
            return;
        }

        isSubmitting = true;

        try
        {
            DateTime? deadline = null;

            if (!string.IsNullOrWhiteSpace(deadlineInput))
            {
                deadline = DateTime.Parse(deadlineInput);
            }

            var task = new StudyTask
            {
                Title = taskModel.Title,
                Description = taskModel.Description,
                SubjectId = taskModel.SubjectId,
                Priority = taskModel.Priority,
                Deadline = deadline
            };

            await TaskService.CreateTaskAsync(task);

            successMessage = "Task created successfully.";
            NavigationManager.NavigateTo("/planner");
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to create task: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class CreateTaskModel
    {
        [Required]
        [StringLength(100, ErrorMessage = "Title can have a maximum of 100 characters.")]
        public string Title { get; set; } = string.Empty;

        [StringLength(500, ErrorMessage = "Description can have a maximum of 500 characters.")]
        public string? Description { get; set; }

        [Range(1, int.MaxValue, ErrorMessage = "Please select a subject.")]
        public int SubjectId { get; set; }

        public int Priority { get; set; } = 2;
    }
}