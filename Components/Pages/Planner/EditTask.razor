@page "/planner/edit/{TaskId:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

@using Microsoft.AspNetCore.Components

@inject TaskService TaskService
@inject SubjectService SubjectService
@inject NavigationManager NavigationManager

<PageTitle>Edit Task - Study Planner</PageTitle>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="mb-4">
                <h1 class="mb-1">Edit Task</h1>
                <p class="text-muted mb-0">Update your study task.</p>
            </div>

            <!-- Displays error messages -->
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            @if (isLoading)
            {
                <!-- Loading state while fetching task data -->
                <div class="text-center py-5">
                    <div class="spinner-border" role="status"></div>
                    <p class="mt-3 text-muted">Loading task...</p>
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">

                        <!-- Form for editing an existing task -->
                        <EditForm Model="taskModel" OnValidSubmit="HandleSubmit" FormName="editTaskForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="alert alert-danger" />

                            <div class="mb-3">
                                <label class="form-label">Task Title</label>
                                <InputText class="form-control" @bind-Value="taskModel.Title" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <InputTextArea class="form-control" rows="4" @bind-Value="taskModel.Description" />
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Subject</label>

                                    <!-- Dropdown populated with user's subjects -->
                                    <InputSelect class="form-select" @bind-Value="taskModel.SubjectId">
                                        @foreach (var subject in subjects)
                                        {
                                            <option value="@subject.Id">@subject.Name</option>
                                        }
                                    </InputSelect>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label">Priority</label>

                                    <!-- Task priority selection -->
                                    <InputSelect class="form-select" @bind-Value="taskModel.Priority">
                                        <option value="1">Low</option>
                                        <option value="2">Medium</option>
                                        <option value="3">High</option>
                                    </InputSelect>
                                </div>
                            </div>

                            <div class="mt-3 mb-3">
                                <label class="form-label">Deadline</label>

                                <!-- Stores deadline as string and converts it later -->
                                <input type="datetime-local" class="form-control" value="@deadlineInput" @onchange="OnDeadlineChanged" />
                            </div>

                            <div class="form-check mb-4">
                                <!-- Allows user to mark task as completed -->
                                <InputCheckbox class="form-check-input" @bind-Value="taskModel.IsCompleted" />
                                <label class="form-check-label">Completed</label>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                    @(isSubmitting ? "Saving..." : "Update Task")
                                </button>
                                <a href="/planner" class="btn btn-outline-secondary">Cancel</a>
                            </div>
                        </EditForm>

                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    // Task ID received from route parameter
    [Parameter]
    public int TaskId { get; set; }

    // Data collections and form model
    private List<Subject> subjects = new();
    private EditTaskModel taskModel = new();

    // UI state
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;

    // Stores deadline input as string for conversion
    private string? deadlineInput;

    /// <summary>
    /// Loads task and subject data when component initializes
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    /// <summary>
    /// Retrieves task and subjects from services
    /// </summary>
    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            subjects = await SubjectService.GetSubjectsByUserAsync();
            var task = await TaskService.GetTaskByIdAsync(TaskId);

            if (task == null)
            {
                errorMessage = "Task not found.";
                return;
            }

            // Map task data to editable model
            taskModel = new EditTaskModel
            {
                Id = task.Id,
                Title = task.Title,
                Description = task.Description,
                SubjectId = task.SubjectId,
                Priority = task.Priority,
                IsCompleted = task.IsCompleted
            };

            // Format deadline for datetime input field
            deadlineInput = task.Deadline?.ToString("yyyy-MM-ddTHH:mm");
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to load task: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Updates deadline value when user selects a new date/time
    /// </summary>
    private void OnDeadlineChanged(ChangeEventArgs e)
    {
        deadlineInput = e.Value?.ToString();
    }

    /// <summary>
    /// Handles form submission and updates the task
    /// </summary>
    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            DateTime? deadline = null;

            // Convert string input to DateTime
            if (!string.IsNullOrWhiteSpace(deadlineInput))
            {
                deadline = DateTime.Parse(deadlineInput);
            }

            // Create updated task object
            var updatedTask = new StudyTask
            {
                Id = taskModel.Id,
                Title = taskModel.Title,
                Description = taskModel.Description,
                SubjectId = taskModel.SubjectId,
                Priority = taskModel.Priority,
                Deadline = deadline,
                IsCompleted = taskModel.IsCompleted
            };

            // Update task via service
            var ok = await TaskService.UpdateTaskAsync(updatedTask);

            if (!ok)
            {
                errorMessage = "Task not found or you do not have permission to edit it.";
                return;
            }

            // Redirect back to dashboard
            NavigationManager.NavigateTo("/planner");
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to update task: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // View model for editing tasks
    public class EditTaskModel
    {
        public int Id { get; set; }

        [Required]
        [StringLength(100)]
        public string Title { get; set; } = string.Empty;

        public string? Description { get; set; }

        public int SubjectId { get; set; }

        public int Priority { get; set; } = 2;

        public bool IsCompleted { get; set; }
    }
}