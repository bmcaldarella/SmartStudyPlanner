@page "/Account/Login"
@using Microsoft.AspNetCore.Identity
@using SmartStudyPlanner.Models
@using SmartStudyPlanner.Models.InputModels

@inject SignInManager<User> SignInManager
@inject NavigationManager NavigationManager

<PageTitle>Login - Study Planner</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg">
                <div class="card-body p-5">
                    <h2 class="card-title text-center mb-4">📚 Login to Study Planner</h2>

                    <!-- Displays error message if login fails -->
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @errorMessage
                            <!-- Clears error message when closed -->
                            <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
                        </div>
                    }

                    <!-- Form for user login -->
                    <EditForm Model="Input" FormName="LoginForm" OnValidSubmit="HandleLogin">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" role="alert" />

                        <div class="mb-3">
                            <label for="email" class="form-label">Email Address</label>
                            <InputText id="email" @bind-Value="Input.Email" class="form-control"
                                       placeholder="Enter your email" type="email" />
                            <ValidationMessage For="() => Input.Email" class="text-danger d-block mt-1" />
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <InputText id="password" @bind-Value="Input.Password" class="form-control"
                                       placeholder="Enter your password" type="password" />
                            <ValidationMessage For="() => Input.Password" class="text-danger d-block mt-1" />
                        </div>

                        <div class="mb-3 form-check">
                            <InputCheckbox id="rememberMe" @bind-Value="Input.RememberMe" class="form-check-input" />
                            <label class="form-check-label" for="rememberMe">
                                Remember me
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">
                            Sign In
                        </button>
                    </EditForm>

                    <div class="text-center">
                        <p class="mb-0">
                            Don't have an account?
                            <a href="/Account/Register" class="text-decoration-none">Register here</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // Holds the form input values (email, password, remember me)
    [SupplyParameterFromForm]
    private LoginInput Input { get; set; } = new();

    // Stores error messages to display to the user
    private string? errorMessage;

    /// <summary>
    /// Handles login form submission and authenticates the user
    /// </summary>
    private async Task HandleLogin()
    {
        try
        {
            // Basic validation to ensure fields are not empty
            if (string.IsNullOrWhiteSpace(Input.Email) || string.IsNullOrWhiteSpace(Input.Password))
            {
                errorMessage = "Please enter both email and password.";
                return;
            }

            // Attempts to sign in the user using ASP.NET Identity
            var result = await SignInManager.PasswordSignInAsync(
                Input.Email,
                Input.Password,
                Input.RememberMe,
                lockoutOnFailure: true);

            if (result.Succeeded)
            {
                // Redirect to home page after successful login
                NavigationManager.NavigateTo("/");
            }
            else if (result.IsLockedOut)
            {
                errorMessage = "Account is locked out due to multiple failed login attempts. Please try again later.";
            }
            else if (result.RequiresTwoFactor)
            {
                // Redirect to 2FA login if required
                NavigationManager.NavigateTo("/Account/LoginWith2fa", forceLoad: true);
            }
            else
            {
                errorMessage = "Invalid email or password. Please try again.";
            }
        }
        catch (NavigationException)
        {
            // Required for Blazor navigation to work correctly during redirects
            throw;
        }
        catch (Exception ex)
        {
            // Handles unexpected errors
            errorMessage = $"An error occurred: {ex.Message}";
        }
    }
}